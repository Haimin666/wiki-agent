# .env.example

# Dynamic API Keys
API_KEY_1=your_api_key_1_here
API_KEY_2=your_api_key_2_here

# Integrations
INTEGRATION_URL=your_integration_url_here
INTEGRATION_KEY=your_integration_key_here

# Database Setup
DATABASE_URL=your_database_url_here
DATABASE_USER=your_database_user_here
DATABASE_PASS=your_database_password_here
DATABASE_NAME=your_database_name_here
